                    <div class="fluid-dock">
                        <a href="https://instagram.com/513sips" target="_blank" class="dock-item" data-label="Instagram">
                            <i data-lucide="instagram" style="width: 22px; height: 22px;"></i>
                        </a>
                        <a href="https://facebook.com/513sips" target="_blank" class="dock-item" data-label="Facebook">
                            <i data-lucide="facebook" style="width: 22px; height: 22px;"></i>
                        </a>
                        <a href="https://tiktok.com/@513sips" target="_blank" class="dock-item" data-label="TikTok">
                            <i data-lucide="music" style="width: 22px; height: 22px;"></i>
                        </a>
                        <a href="mailto:hello@513sips.com" class="dock-item" data-label="Email">
                            <i data-lucide="mail" style="width: 22px; height: 22px;"></i>
                        </a>
                    </div>
                </div>
                <div class="footer-column">
                    <h4>Services</h4>
                    <ul class="footer-links">
                        <li><a href="#services">Weddings</a></li>
                        <li><a href="#services">Corporate Events</a></li>
                        <li><a href="#services">Private Parties</a></li>
                        <li><a href="#pricing">Pricing</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Company</h4>
                    <ul class="footer-links">
                        <li><a href="#about">About Us</a></li>
                        <li><a href="#team">Our Team</a></li>
                        <li><a href="#gallery">Gallery</a></li>
                        <li><a href="#contact">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Support</h4>
                    <ul class="footer-links">
                        <li><a href="#faq">FAQ</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 513 Sips. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        lucide.createIcons();
        gsap.registerPlugin(ScrollTrigger);

        // Hero animations
        const heroTl = gsap.timeline();
        heroTl.to('.hero-subtitle', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' })
        .to('.hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' }, '-=0.7')
        .to('.hero-description', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' }, '-=0.7')
        .to('.hero-buttons', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' }, '-=0.7')
        .to('.hero-scroll', { opacity: 1, duration: 1, ease: 'power3.out' }, '-=0.5');

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // Tubelight highlight effect
        const tubelightLinks = document.querySelectorAll('.tubelight-link');
        const tubelightHighlight = document.getElementById('tubelight-highlight');
        const tubelightLinksContainer = document.getElementById('tubelight-links');

        function updateHighlight(link) {
            const rect = link.getBoundingClientRect();
            const containerRect = tubelightLinksContainer.getBoundingClientRect();
            tubelightHighlight.style.width = rect.width + 'px';
            tubelightHighlight.style.left = (rect.left - containerRect.left) + 'px';
        }

        const activeLink = document.querySelector('.tubelight-link.active');
        if (activeLink) {
            setTimeout(() => updateHighlight(activeLink), 100);
        }

        tubelightLinks.forEach(link => {
            link.addEventListener('mouseenter', () => updateHighlight(link));
            link.addEventListener('click', (e) => {
                tubelightLinks.forEach(l => l.classList.remove('active'));
                link.classList.add('active');
                updateHighlight(link);
            });
        });

        tubelightLinksContainer.addEventListener('mouseleave', () => {
            const active = document.querySelector('.tubelight-link.active');
            if (active) updateHighlight(active);
        });

        // Mobile menu
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileMenuClose = document.getElementById('mobile-menu-close');

        mobileMenuBtn.addEventListener('click', () => mobileMenu.classList.add('active'));
        mobileMenuClose.addEventListener('click', () => mobileMenu.classList.remove('active'));
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => mobileMenu.classList.remove('active'));
        });

        // Scroll animations
        gsap.utils.toArray('.service-card').forEach((card, i) => {
            gsap.from(card, {
                scrollTrigger: { trigger: card, start: 'top 85%', toggleActions: 'play none none reverse' },
                opacity: 0, y: 50, duration: 0.6, delay: i * 0.1, ease: 'power3.out'
            });
        });

        gsap.from('.about-image', {
            scrollTrigger: { trigger: '.about', start: 'top 70%' },
            opacity: 0, x: -50, duration: 0.8, ease: 'power3.out'
        });

        gsap.from('.about-content', {
            scrollTrigger: { trigger: '.about', start: 'top 70%' },
            opacity: 0, x: 50, duration: 0.8, delay: 0.2, ease: 'power3.out'
        });

        gsap.utils.toArray('.team-card').forEach((card, i) => {
            gsap.from(card, {
                scrollTrigger: { trigger: card, start: 'top 85%' },
                opacity: 0, y: 50, duration: 0.6, delay: i * 0.1, ease: 'power3.out'
            });
        });

        gsap.utils.toArray('.flip-card').forEach((card, i) => {
            gsap.to(card, {
                scrollTrigger: { trigger: card, start: 'top 85%' },
                opacity: 1, y: 0, duration: 0.6, delay: i * 0.05, ease: 'power3.out'
            });
        });

        // Gallery filter
        const galleryFilters = document.querySelectorAll('.gallery-filter');
        const galleryCards = document.querySelectorAll('.flip-card');

        galleryFilters.forEach(filter => {
            filter.addEventListener('click', () => {
                galleryFilters.forEach(f => f.classList.remove('active'));
                filter.classList.add('active');
                const category = filter.dataset.filter;

                galleryCards.forEach(card => {
                    if (category === 'all' || card.dataset.category === category) {
                        card.style.display = 'block';
                        gsap.to(card, { opacity: 1, scale: 1, duration: 0.4, ease: 'power2.out' });
                    } else {
                        gsap.to(card, { opacity: 0, scale: 0.8, duration: 0.4, ease: 'power2.out', onComplete: () => { card.style.display = 'none'; } });
                    }
                });
            });
        });

        // Testimonials auto-rotation
        const testimonialItems = document.querySelectorAll('.testimonial-item');
        const testimonialDots = document.querySelectorAll('.testimonial-dot');
        let currentTestimonial = 0;
        let testimonialInterval;

        function showTestimonial(index) {
            testimonialItems.forEach((item, i) => {
                item.classList.remove('active');
                testimonialDots[i].classList.remove('active');
            });
            testimonialItems[index].classList.add('active');
            testimonialDots[index].classList.add('active');
            currentTestimonial = index;
        }

        function nextTestimonial() {
            const next = (currentTestimonial + 1) % testimonialItems.length;
            showTestimonial(next);
        }

        function startTestimonialRotation() {
            testimonialInterval = setInterval(nextTestimonial, 5000);
        }

        testimonialDots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                clearInterval(testimonialInterval);
                showTestimonial(index);
                startTestimonialRotation();
            });
        });

        startTestimonialRotation();

        // FAQ accordion
        const faqItems = document.querySelectorAll('.faq-item');
        faqItems.forEach(item => {
            const question = item.querySelector('.faq-question');
            question.addEventListener('click', () => {
                const isActive = item.classList.contains('active');
                faqItems.forEach(i => i.classList.remove('active'));
                if (!isActive) item.classList.add('active');
            });
        });

        // Pricing calculator
        const eventType = document.getElementById('event-type');
        const guestCount = document.getElementById('guest-count');
        const hours = document.getElementById('hours');
        const bartenders = document.getElementById('bartenders');
        const serviceLevel = document.getElementById('service-level');
        const estimateAmount = document.getElementById('estimate-amount');
        const baseFeeEl = document.getElementById('base-fee');
        const bartenderFeeEl = document.getElementById('bartender-fee');
        const serviceFeeEl = document.getElementById('service-fee');
        const totalFeeEl = document.getElementById('total-fee');

        function calculateEstimate() {
            const baseFees = { wedding: 500, corporate: 400, private: 300 };
            const serviceMultipliers = { basic: 1, standard: 1.5, premium: 2.5 };

            const base = baseFees[eventType.value] || 400;
            const bartenderCost = parseInt(bartenders.value) * 50 * parseInt(hours.value);
            const serviceCost = (parseInt(guestCount.value) * 3) * serviceMultipliers[serviceLevel.value];
            const total = base + bartenderCost + serviceCost;

            estimateAmount.textContent = '$' + total.toLocaleString();
            baseFeeEl.textContent = '$' + base.toLocaleString();
            bartenderFeeEl.textContent = '$' + bartenderCost.toLocaleString() + ' (' + bartenders.value + ' bartenders)';
            serviceFeeEl.textContent = '$' + serviceCost.toLocaleString();
            totalFeeEl.textContent = '$' + total.toLocaleString();
        }

        [eventType, guestCount, hours, bartenders, serviceLevel].forEach(input => {
            input.addEventListener('change', calculateEstimate);
            input.addEventListener('input', calculateEstimate);
        });

        // Contact form
        document.getElementById('booking-form').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Thank you for your inquiry! We will be in touch soon.');
            e.target.reset();
        });

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        // Section header animations
        gsap.utils.toArray('section').forEach(section => {
            gsap.from(section.querySelectorAll('.section-header'), {
                scrollTrigger: { trigger: section, start: 'top 80%' },
                opacity: 0, y: 30, duration: 0.8, ease: 'power3.out'
            });
        });
    </script>
</body>
</html>
