                        <i data-lucide="instagram" class="instagram-icon"></i>
                    </div>
                </div>
                <div class="instagram-item">
                    <img src="https://images.unsplash.com/photo-1544145945-f90425340c7e?w=400&h=400&fit=crop" alt="Instagram 6">
                    <div class="instagram-overlay">
                        <i data-lucide="instagram" class="instagram-icon"></i>
                    </div>
                </div>
                <div class="instagram-item">
                    <img src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?w=400&h=400&fit=crop" alt="Instagram 1">
                    <div class="instagram-overlay">
